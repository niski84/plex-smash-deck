{
  "name": "plex-dashboard",
  "version": "1.0.0",
  "description": "Standalone Go web app for browsing a Plex movie library, TMDB discovery / gap analysis, Radarr add, and movie snapshots.",
  "main": "index.js",
  "directories": {
    "doc": "docs"
  },
  "scripts": {
    "demo": "PLAYWRIGHT_BROWSERS_PATH=/home/nick/.cache/ms-playwright playwright test scripts/demo.spec.ts --config=playwright.config.ts",
    "test:players": "playwright test scripts/players.spec.ts --config=playwright.config.ts",
    "test:discovery-popup": "playwright test scripts/discovery-popup.spec.ts --config=playwright.config.ts",
    "test:lightbox-clipboard": "playwright test scripts/lightbox-clipboard.spec.ts --config=playwright.config.ts",
    "demo:gif": "bash scripts/make-demo-gif.sh"
  },
  "repository": {
