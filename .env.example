# Copy to .env and fill in. Same variables as docs/00-getting-started.md
# Plex (required for most features)
PLEX_BASE_URL=http://192.168.1.10:32400
PLEX_TOKEN=
PLEX_LIBRARY_KEY=1
PLEX_TARGET_CLIENT_NAME=Living Room

# TMDB (required for Discovery / posters)
TMDB_API_KEY=

# HTTP port inside the container (compose maps host:container with the same value)
PORT=8081

# Optional
# LGTV_ADDR=
# LGTV_CLIENT_KEY=
# OMDB_API_KEY=
# RADARR_URL=
# RADARR_API_KEY=
# FANART_API_KEY=
